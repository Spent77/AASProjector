    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "satellite.js": "^5.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "@deck.gl/core": "^9.0.30",
    "@deck.gl/layers": "^9.0.30",
    "@deck.gl/mapbox": "^9.0.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "maplibre-gl": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "zustand": "^4.5.4"
